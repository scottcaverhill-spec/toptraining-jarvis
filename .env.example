OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4-mini

# Version A / Vercel subdomain:
# Leave this blank when deploying to https://jarvis.toptrainingacademy.com
# NEXT_PUBLIC_BASE_PATH=

# Version B / GoDaddy path app:
# Use /jarvis when the cPanel Node app lives at https://toptrainingacademy.com/jarvis
NEXT_PUBLIC_BASE_PATH=/jarvis

# Optional: if OPENAI_API_KEY is not available, Jarvis can proxy the existing Academy API.
TOP_ACADEMY_CHAT_API=https://toptrainingacademy.com/api/chat

# Local development JSON store. For Vercel/serverless production use Supabase, Vercel Postgres, or another database.
AGENT_STORE_PATH=./data/agents.json

# Optional durable shared Jarvis agent storage.
# If one of these is configured, Jarvis saves created agents to Postgres instead of temporary serverless storage.
POSTGRES_URL=
POSTGRES_DATABASE_URL=
AGENT_DATABASE_URL=

# Optional: set to true only if you want each saved agent mirrored to OpenAI Assistants.
OPENAI_CREATE_ASSISTANTS=false

# Optional: live Toyota of Portland Google review feed for the academy footer.
# Use a server-side Google Places API key. Do not put this key in browser JavaScript.
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
GOOGLE_TOYOTA_OF_PORTLAND_PLACE_ID=your_google_place_id_here

# GoDaddy fallback only:
# Set true if shared hosting cannot run/install Next.js and you want the lightweight server.js page.
USE_STATIC_JARVIS=false
